# ============================================================
# JARVIS AI — Environment Variables
# Copy this to .env.local and fill in your keys
# ============================================================

# === HIGH PRIORITY (Performance) ===
GROQ_API_KEY=                    # console.groq.com — free
GEMINI_API_KEY=                  # aistudio.google.com — free
NEXT_PUBLIC_GEMINI_API_KEY=      # same as GEMINI_API_KEY
GITHUB_PAT=                      # github.com → Settings → Tokens (Classic) — scope: repo+gist
VERCEL_TOKEN=                    # vercel.com → Settings → Tokens

# === MEDIUM PRIORITY (More fallbacks) ===
TOGETHER_API_KEY=                # together.ai — $25 free credit
CEREBRAS_API_KEY=                # cerebras.ai — free tier
MISTRAL_API_KEY=                 # console.mistral.ai — free
COHERE_API_KEY=                  # cohere.com — free
FIREWORKS_API_KEY=               # fireworks.ai — free
DEEPINFRA_API_KEY=               # deepinfra.com — free
HUGGINGFACE_API_KEY=             # huggingface.co — free
OPENROUTER_API_KEY=              # openrouter.ai — DeepSeek R1

# === LOW PRIORITY (Tools) ===
NASA_API_KEY=DEMO_KEY            # works without real key (50/day)
GNEWS_API_KEY=                   # gnews.io — 100/day
NEWSAPI_KEY=                     # newsapi.org — 100/day
OMDB_API_KEY=                    # omdbapi.com — 1000/day
OPENWEATHER_API_KEY=             # openweathermap.org — backup weather
SERPER_API_KEY=                  # serper.dev — 2500/month

# === OPTIONAL ===
NEXT_PUBLIC_SUPABASE_URL=        # supabase.com (optional cloud sync)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # supabase.com (optional cloud sync)
